{
  "manifest_version": 3,
  "name": "Next.js Pretty View Source",
  "version": "1.5.1",
  "description": "Pretty view source for Next.js pages - opens in a full tab with syntax highlighting",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Next.js Pretty View Source"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}